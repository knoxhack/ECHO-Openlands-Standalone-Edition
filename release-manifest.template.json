  "requiredModuleDescriptors": [
    "META-INF/echo.mod.json"
  ],
  "optionalPackageDescriptors": [
    "echo-addon-package.json"
  ],
  "requiredRuntimeEvidenceContract": "data/echoopenlandsprotocol/openlands/systems/runtime_adapter_load_plan.json",
