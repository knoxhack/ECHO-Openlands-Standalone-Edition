    },
    {
      "id": "echorecipecore",
      "version": ">=1.0.0"
    },
    {
      "id": "echobiomecore",
      "version": ">=1.0.0"
    },
    {
      "id": "echostructurecore",
      "version": ">=1.0.0"
    },
    {
      "id": "echocreaturecore",
